# GitHub personal access token with permissions for follow + starring.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Ollama instance.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Search.
LANGUAGE=Python
MAX_STARS=100

# Pipeline thresholds (idea + skill, each in [1.0, 10.0]).
FETCH_COUNT=5
SUBSCRIBE_THRESHOLD=14.0
STAR_THRESHOLD=16.0
WINDOW_HOURS=24

# Local paths.
DB_PATH=data/followme.sqlite
REPO_DIR=data/repo

# Clone + digest tuning.
CLONE_DEPTH=1
MAX_FILES=20
MAX_LINES_PER_FILE=80
MAX_CHARS_PER_FILE=4000
MAX_TOTAL_CHARS=40000
MAX_FILE_BYTES=262144
EXTENSIONS=.py,.pyi,.js,.ts,.tsx,.jsx,.go,.rs,.java,.kt,.c,.h,.cpp,.hpp,.cs,.php,.rb,.swift,.scala,.lua,.sh,.sql,.yaml,.yml,.toml,.md

# Network.
HTTP_TIMEOUT=30

# Safety.
DRY_RUN=false
